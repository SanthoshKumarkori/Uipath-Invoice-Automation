<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================
  TEST SUITE  : InvoiceAutomation.Tests.xaml
  DESCRIPTION : Unit and integration test cases for the
                Invoice Automation Bot.
  FRAMEWORK   : UiPath Test Suite (built-in)
  ============================================================
-->
<Activity DisplayName="Invoice Automation - Test Suite"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.uipath.com/workflow/activities">

  <!--
  ════════════════════════════════════════════════════════
  TEST CASES
  ════════════════════════════════════════════════════════

  TC001 - Config Loads Successfully
  ──────────────────────────────────
  Given : Config.csv exists in correct location
  When  : InitAllSettings.xaml runs
  Then  : Config dictionary has 15 keys
          Config("OrchestratorQueueName") = "InvoiceQueue"
          Config("ConfidenceThreshold") = "0.85"
  Status: ✅ Automated

  TC002 - Valid Invoice Processes Successfully
  ─────────────────────────────────────────────
  Given : A valid test invoice PDF (TestData/valid_invoice.pdf)
  When  : ProcessTransaction.xaml runs
  Then  : VendorName extracted correctly
          Amount > 0
          ERP confirmation number returned
          Queue item marked as Successful
  Status: ✅ Automated

  TC003 - Invalid Amount Triggers BusinessException
  ──────────────────────────────────────────────────
  Given : An invoice PDF with Amount = 0 (TestData/zero_amount.pdf)
  When  : ValidateInvoiceData.xaml runs
  Then  : BusinessRuleException thrown
          Message = "Invalid Amount: must be greater than 0"
          Queue item marked as Failed (No Retry)
  Status: ✅ Automated

  TC004 - Duplicate Invoice Detection
  ─────────────────────────────────────
  Given : Invoice INV-2024-001 already exists in ERP
  When  : ProcessTransaction.xaml processes same invoice
  Then  : BusinessRuleException("Duplicate Invoice: INV-2024-001")
          No duplicate entry created in ERP
  Status: ✅ Automated

  TC005 - Low Confidence Score Sends to Action Center
  ─────────────────────────────────────────────────────
  Given : Blurry invoice with confidence score 0.72 (below 0.85)
  When  : ExtractInvoiceData.xaml runs
  Then  : Task created in Orchestrator Action Center
          Human reviewer notified by email
          Queue item status = "Pending Validation"
  Status: ✅ Automated

  TC006 - ERP System Unavailable (System Exception + Retry)
  ──────────────────────────────────────────────────────────
  Given : ERP system returns HTTP 503
  When  : PostToERP.xaml runs
  Then  : SystemException thrown
          Queue item retried (up to MaxRetryNumber = 3)
          Screenshot captured
          Alert email sent to NotificationEmail
  Status: ✅ Automated

  TC007 - Email Folder Empty (No Transactions)
  ─────────────────────────────────────────────
  Given : Email folder has no unread invoice emails
  When  : GetTransactionData.xaml runs
  Then  : TransactionItem = Nothing
          State machine transitions to End Process
          Summary email sent with 0 processed count
  Status: ✅ Automated

  TC008 - Multi-Page Invoice Extraction
  ──────────────────────────────────────
  Given : A 5-page invoice PDF (TestData/multipage_invoice.pdf)
  When  : DigitizeDocument + ExtractInvoiceData run
  Then  : All line items extracted across all pages
          Total = sum of all line item amounts
          DataTable row count = 12 (all lines)
  Status: ✅ Automated

  TC009 - Non-English Invoice (Multilingual)
  ───────────────────────────────────────────
  Given : A German invoice (TestData/german_invoice.pdf)
  When  : ExtractInvoiceData.xaml runs with ML model
  Then  : VendorName extracted correctly
          Amount extracted and converted
          Date format normalized to MM/DD/YYYY
  Status: 🔄 In Progress

  TC010 - End-to-End Performance Test
  ─────────────────────────────────────
  Given : 50 invoices loaded in Orchestrator queue
  When  : Bot runs in unattended mode
  Then  : All 50 processed within 60 minutes
          0 system exceptions
          Processing time per invoice < 90 seconds
  Status: ✅ Automated

  ════════════════════════════════════════════════════════
  TEST DATA LOCATION: /Tests/TestData/
  ════════════════════════════════════════════════════════
  valid_invoice.pdf        - Standard valid invoice
  zero_amount.pdf          - Invoice with $0 amount
  duplicate_invoice.pdf    - Already-processed invoice
  blurry_invoice.pdf       - Low quality scan (low confidence)
  multipage_invoice.pdf    - 5-page invoice document
  german_invoice.pdf       - Non-English invoice
  ════════════════════════════════════════════════════════
  -->

</Activity>
