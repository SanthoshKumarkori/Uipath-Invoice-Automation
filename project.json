{
  "name": "UiPath-Invoice-Automation",
  "description": "Automated Invoice Processing Bot using UiPath REFramework. Reads invoices from email/folder, extracts data using Document Understanding, validates, and posts to ERP system.",
  "main": "Workflows/Main.xaml",
  "outputType": "Process",
  "expressionLanguage": "VisualBasic",
  "targetFramework": "Portable",
  "runtimeOptions": {
    "autoDispose": false,
    "isPausable": true,
    "requiresUserInteraction": false,
    "supportsPersistence": false
  },
  "designOptions": {
    "projectProfile": "Robotic Enterprise Framework",
    "outputType": "Process",
    "libraryIdenticalVersionsAllowed": false
  },
  "dependencies": {
    "UiPath.Excel.Activities": "[2.21.2]",
    "UiPath.Mail.Activities": "[1.20.2]",
    "UiPath.System.Activities": "[23.10.3]",
    "UiPath.UIAutomation.Activities": "[23.10.3]",
    "UiPath.DocumentUnderstanding.ML.Activities": "[1.18.0]",
    "UiPath.IntelligentOCR.Activities": "[6.8.0]",
    "UiPath.Orchestrator.Activities": "[1.0.0]"
  },
  "version": "1.0.0",
  "studio": {
    "version": "23.10.0"
  }
}
