<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================
  WORKFLOW   : ProcessTransaction.xaml
  DESCRIPTION: Core business logic for invoice processing.
               Steps:
               1. Download invoice from email attachment
               2. Digitize document using Document Understanding
               3. Extract fields (Vendor, Date, Amount, Lines)
               4. Validate extracted data
               5. Post to ERP system
               6. Archive processed invoice
  AUTHOR     : Your Name
  VERSION    : 1.0.0
  ============================================================
-->
<Activity
  x:Class="UiPathInvoiceAutomation.ProcessTransaction"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  DisplayName="Process Transaction">

  <!--
  ════════════════════════════════════════════════════════
  ARGUMENT DEFINITIONS
  ════════════════════════════════════════════════════════
  in_Config          : Dictionary(String, String) - All config values
  in_TransactionItem : QueueItem                  - Current queue item
  out_TransactionStatus : String                  - Success/Failed
  out_BusinessException : BusinessRuleException   - If validation fails
  ════════════════════════════════════════════════════════

  STEP 1 — DOWNLOAD INVOICE
  ─────────────────────────
  Activity : Get Mail Messages (IMAP/Exchange)
  Filter   : Subject Contains "Invoice" AND Unread
  Action   : Save attachment to in_Config("InvoiceOutputPath")
  Output   : invoiceFilePath As String

  STEP 2 — DIGITIZE DOCUMENT
  ──────────────────────────
  Activity : Digitize Document (Document Understanding)
  Input    : invoiceFilePath
  Endpoint : in_Config("DocumentUnderstandingEndpoint")
  Output   : documentObjectModel As Document

  STEP 3 — EXTRACT DATA FIELDS
  ─────────────────────────────
  Activity : Extract Document Data (ML Extractor)
  Model    : InvoiceModel (trained in AI Center)
  Fields Extracted:
    ├── VendorName     : String
    ├── VendorAddress  : String
    ├── InvoiceNumber  : String
    ├── InvoiceDate    : DateTime
    ├── DueDate        : DateTime
    ├── TotalAmount    : Decimal
    ├── TaxAmount      : Decimal
    ├── Currency       : String
    └── LineItems()    : DataTable
         ├── Description
         ├── Quantity
         ├── UnitPrice
         └── LineTotal
  Confidence Threshold : in_Config("ConfidenceThreshold") = 0.85

  STEP 4 — VALIDATE DATA
  ───────────────────────
  Rules:
    IF TotalAmount <= 0          → Throw BusinessRuleException("Invalid Amount")
    IF VendorName = ""           → Throw BusinessRuleException("Missing Vendor")
    IF InvoiceDate > Today       → Throw BusinessRuleException("Future Invoice Date")
    IF InvoiceNumber Duplicate   → Throw BusinessRuleException("Duplicate Invoice")
    IF Confidence < Threshold    → Flag for Human Review via Action Center

  STEP 5 — POST TO ERP SYSTEM
  ────────────────────────────
  Activity : Open Browser → in_Config("ERPSystemURL")
  Actions  :
    → Navigate to Invoice Entry screen
    → Type VendorName into Vendor field
    → Type InvoiceNumber into Invoice# field
    → Type InvoiceDate into Date field
    → Type TotalAmount into Amount field
    → For each row in LineItems → Add line item
    → Click Submit button
    → Capture confirmation number
    → Screenshot confirmation page

  STEP 6 — ARCHIVE & UPDATE STATUS
  ──────────────────────────────────
  → Move invoice file to Archive folder
  → Add confirmation number to queue item output
  → Set out_TransactionStatus = "Success"
  → Log: "Invoice {InvoiceNumber} processed. Confirmation: {ConfirmationNo}"
  ════════════════════════════════════════════════════════
  -->

  <ui:Sequence DisplayName="Process Invoice Transaction">

    <ui:TryCatch DisplayName="Try - Process Invoice">
      <ui:TryCatch.Try>
        <ui:Sequence>
          <!-- Step 1: Download Invoice -->
          <ui:InvokeWorkflowFile
            WorkflowFileName="Workflows/DownloadInvoice.xaml"
            DisplayName="1. Download Invoice from Email" />

          <!-- Step 2: Digitize using Document Understanding -->
          <ui:InvokeWorkflowFile
            WorkflowFileName="Workflows/DigitizeDocument.xaml"
            DisplayName="2. Digitize Invoice Document" />

          <!-- Step 3: Extract Fields -->
          <ui:InvokeWorkflowFile
            WorkflowFileName="Workflows/ExtractInvoiceData.xaml"
            DisplayName="3. Extract Invoice Fields (ML Model)" />

          <!-- Step 4: Validate Data -->
          <ui:InvokeWorkflowFile
            WorkflowFileName="Workflows/ValidateInvoiceData.xaml"
            DisplayName="4. Validate Business Rules" />

          <!-- Step 5: Post to ERP -->
          <ui:InvokeWorkflowFile
            WorkflowFileName="Workflows/PostToERP.xaml"
            DisplayName="5. Post Invoice to ERP System" />

          <!-- Step 6: Archive -->
          <ui:InvokeWorkflowFile
            WorkflowFileName="Workflows/ArchiveInvoice.xaml"
            DisplayName="6. Archive Processed Invoice" />
        </ui:Sequence>
      </ui:TryCatch.Try>

      <ui:TryCatch.Catches>
        <!-- Handle Business Rule Exceptions (no retry) -->
        <ui:Catch x:TypeArguments="ui:BusinessRuleException">
          <ui:Sequence DisplayName="Handle Business Exception">
            <ui:Log DisplayName="Log Business Exception" Level="Warn" />
          </ui:Sequence>
        </ui:Catch>

        <!-- Handle System Exceptions (will retry) -->
        <ui:Catch x:TypeArguments="x:Exception">
          <ui:Sequence DisplayName="Handle System Exception">
            <ui:TakeScreenshot DisplayName="Screenshot on Error" />
            <ui:Log DisplayName="Log System Exception" Level="Error" />
            <ui:Rethrow />
          </ui:Sequence>
        </ui:Catch>
      </ui:TryCatch.Catches>
    </ui:TryCatch>

  </ui:Sequence>
</Activity>
